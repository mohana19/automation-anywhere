# ---------------------------------------------------------------------------
# Automation Anywhere Community Edition — environment configuration
# Copy this file to `.env` and fill in the values for YOUR account.
# `.env` is git-ignored; never commit real credentials.
# ---------------------------------------------------------------------------

# Control Room base URL assigned to your account after you register at
# https://www.automationanywhere.com/products/enterprise/community-edition
# Example (your cluster/number may differ):
#   https://community.cloud.automationanywhere.digital
#   https://community2.cloud.automationanywhere.digital
CR_URL=https://community.cloud.automationanywhere.digital

# Login credentials (the personal email + password you registered with).
AA_USERNAME=mohanasreenidhi@gmail.com
AA_PASSWORD=Mohana@1916

# API authentication.
# Prefer an API key (Control Room > My Settings > Generate API key) over the
# password for the API tests. Leave blank to fall back to AA_PASSWORD.
AA_API_KEY=

# Absolute or relative path to the document uploaded in Use Case 1.
# Defaults to the bundled fixture if unset.
UPLOAD_FILE_PATH=fixtures/sample-upload.txt
