{
  "name": "aa-automation-assignment",
  "version": "1.0.0",
  "description": "Playwright + TypeScript automation for Automation Anywhere Community Edition: UI form-with-upload flow (POM) and API-driven form/process creation.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --project=ui --headed",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["playwright", "typescript", "pom", "automation-anywhere", "api-testing"],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.0"
  }
}
